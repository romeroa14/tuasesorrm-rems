# Copiar: cp deploy/docker/.env.example deploy/docker/.env
# Solo usado por docker compose (cargado autom. desde deploy/docker/ como directorio del compose).
# No subir deploy/docker/.env a git.
#
# Sustituye TODA palabra "cambiar_..." y contraseñas de ejemplo ANTES del primer
#   docker compose up, o ajusta luego con ALTER USER (ver deploy/docker/README).
#   Si dejas "cambiar_user_seguro", el usuario rems ESA será su contraseña en MySQL.

# MySQL 8 (servicio rems-mysql)
# IMPORTANTE: mismo usuario / base / contraseña REAL que en el .env de CodeIgniter (raíz del repo).
#   database.default.database   = REMS_MYSQL_DATABASE
#   database.default.username     = REMS_MYSQL_USER
#   database.default.hostname     = rems-mysql
# En el .env de CodeIgniter la password va SIN regla $$ (ej. "Rems20$"). En ESTE fichero,
# si la clave lleva $, usa $$ (Compose). Ver tabla "Los dos .env" en deploy/docker/README.md
#
# El nombre de base solo se aplica en el PRIMER arranque del volumen MySQL. Si ya existía el volumen con
# otro nombre de base, o cambiaste contraseñas después, ver deploy/docker/README.md (troubleshooting).
#
# OJO: en Docker Compose, en ESTE fichero un signo $ literal se escribe como $$  (si no, Compose lo
# interpreta como variable y la contraseña en MySQL queda mal → Access denied en migrate).
# Ejemplo: contraseña deseada Rems20$  →  REMS_MYSQL_PASSWORD=Rems20$$

REMS_MYSQL_ROOT_PASSWORD=cambiar_root_seguro
REMS_MYSQL_DATABASE=rems
REMS_MYSQL_USER=rems
REMS_MYSQL_PASSWORD=cambiar_user_seguro
